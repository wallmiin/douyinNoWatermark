# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Douyin session cookie (recommended for stability)
DOUYIN_COOKIE=

# Optional custom user-agent
DOUYIN_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36

# Download directory
DOWNLOAD_ROOT=./downloads

# Queue
QUEUE_NAME=douyin-video-download

# Request settings
REQUEST_TIMEOUT_MS=25000
