{
  "name": "douyin-profile-downloader",
  "version": "1.0.0",
  "description": "Production-ready Douyin profile video downloader (no-watermark via play_addr)",
  "main": "app.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node app.js",
    "start:api": "ts-node src/main.ts",
    "start:dev": "ts-node src/cli.ts",
    "start:web": "npm run dev --prefix frontend",
    "install:web": "npm install --prefix frontend",
    "lint": "echo \"No lint configured\""
  },
  "dependencies": {
    "@nestjs/common": "^10.4.8",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.8",
    "@nestjs/platform-express": "^10.4.8",
    "axios": "^1.9.0",
    "better-sqlite3": "^11.8.1",
    "bullmq": "^5.12.12",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.4.1",
    "minimist": "^1.2.8",
    "puppeteer": "^24.6.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.15.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
